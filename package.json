{
    "name": "teknoify-site",
    "version": "1.0.0",
    "private": true,
    "description": "Teknoify static multi-page website",
    "scripts": {
        "format": "prettier --write \"**/*.{html,css,js,md,json}\"",
        "format:check": "prettier --check \"**/*.{html,css,js,md,json}\"",
        "lint:js": "eslint js/**/*.js",
        "lint:css": "stylelint \"css/**/*.css\"",
        "check": "npm run format:check && npm run lint:js && npm run lint:css",
        "check:architecture": "node scripts/architecture/check-enterprise-migration-readiness.js",
        "check:investment-runtime": "node scripts/architecture/check-investment-runtime-map.js",
        "check:public-mirrors": "node scripts/architecture/check-public-page-mirror-source-policy.js",
        "check:dashboard-routes": "node scripts/architecture/check-dashboard-route-readiness.js && node scripts/architecture/check-dashboard-route-compatibility.js",
        "update:usdtry": "node scripts/update-usd-try-rates.mjs",
        "build:stock-doc-catalog": "node scripts/build-stock-document-catalog.mjs",
        "extract:stock-doc-text": "python scripts/extract-stock-document-text.py",
        "search:stock-doc-text": "node scripts/search-stock-document-text.mjs",
        "check:readiness-seal": "node scripts/architecture/check-enterprise-readiness-seal.js"
    },
    "devDependencies": {
        "stylelint": "file:tools/stylelint",
        "stylelint-config-standard": "file:tools/stylelint-config-standard"
    },
    "dependencies": {
        "firebase-admin": "^13.7.0"
    }
}
